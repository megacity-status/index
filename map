<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>マルハンメガシティ静岡 状況マップ</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: "Helvetica Neue", Arial, "Hiragino Kaku Gothic ProN", "Hiragino Sans", Meiryo, sans-serif; background: #ddd; padding: 10px; }

/* ツールバー */
#toolbar {
  position: sticky; top: 0; background: #222; color: #fff;
  padding: 8px 12px; z-index: 1000; border-radius: 4px;
  display: flex; align-items: center; gap: 15px; flex-wrap: wrap;
  margin-bottom: 10px;
}
#toolbar h1 { font-size: 14px; font-weight: bold; }
#resetBtn { padding: 4px 12px; background: #e44; color: #fff; border: none; border-radius: 3px; cursor: pointer; font-size: 12px; font-weight: bold; }
#resetBtn:hover { background: #f33; }
.legend { display: flex; gap: 10px; align-items: center; font-size: 12px; }
.lb { width: 16px; height: 16px; border: 1px solid #888; display: inline-block; vertical-align: middle; border-radius: 2px; }

/* 全体コンテナ */
#scroll { overflow-x: auto; background: #ddd; padding: 5px; }
.map-container {
  width: 1020px;
  background: #fff;
  border: 1px solid #999;
  padding: 15px;
  margin: 0 auto;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

/* タイトル */
.map-title {
  text-align: center;
  font-size: 15px;
  font-weight: bold;
  padding-bottom: 15px;
  border-bottom: 2px solid #333;
  margin-bottom: 15px;
}

/* 最上段エリア */
.top-row { display: flex; justify-content: space-between; margin-bottom: 15px; padding: 0 50px; }

/* メイン格子エリア（左縦列・中央エリア・右縦列） */
.main-layout { display: grid; grid-template-columns: 80px 1fr 80px; gap: 15px; }

/* 左右の縦列列 */
.side-column { display: flex; flex-direction: column; border: 1px solid #aaa; background: #fafafa; }
.side-block { display: flex; border-bottom: 1px solid #ccc; min-height: 50px; }
.side-block:last-child { border-bottom: none; }
.label-v {
  writing-mode: vertical-rl; text-align: center; font-size: 9px; font-weight: bold;
  padding: 4px; background: #eee; border-right: 1px solid #ccc; width: 24px;
  display: flex; align-items: center; justify-content: center;
}
.side-block.right .label-v { border-right: none; border-left: 1px solid #ccc; }
.side-m-list { display: flex; flex-direction: column; flex: 1; justify-content: flex-start; }

/* 中央エリア */
.center-layout { display: flex; flex-direction: column; gap: 10px; }
.center-row { display: flex; justify-content: space-between; align-items: center; gap: 10px; }
.center-aisle {
  text-align: center; background: #eee; font-weight: bold; font-size: 11px;
  padding: 4px; border: 1px solid #ccc; letter-spacing: 5px; margin: 5px 0;
}

/* 島・ボックス共通 */
.gbox { border: 1px solid #aaa; background: #fafafa; display: flex; flex-direction: column; align-items: center; padding: 2px; }
.gbox-label { font-size: 9px; font-weight: bold; text-align: center; background: #fff; width: 100%; padding: 2px 0; border-bottom: 1px solid #eee; margin-bottom: 2px; }
.mrow { display: flex; }

/* 中央縦型配置用 */
.center-combine { display: flex; justify-content: space-between; width: 100%; }
.v-island-group { display: flex; gap: 4px; }

/* 下部エリア */
.bottom-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; border-top: 2px dashed #ccc; padding-top: 20px; }
.bottom-left, .bottom-right { display: flex; flex-direction: column; gap: 10px; }

/* 円卓風ボックス */
.round-box { border: 1px solid #999; padding: 10px; background: #fdfdfd; }
.grid-table { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: #aaa; border: 1px solid #aaa; }
.grid-cell { background: #fff; padding: 3px; font-size: 9px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; min-height: 32px; }
.grid-cell .num { font-weight: bold; color: #111; }
.grid-cell .name { font-size: 8px; color: #555; transform: scale(0.9); }

/* 4x4バラエティ */
.grid-4x4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #aaa; border: 1px solid #aaa; }

/* 横一列並び */
.h-row { display: flex; border: 1px solid #aaa; background: #fafafa; padding: 2px; justify-content: center; }
.h-row-cell { display: flex; flex-direction: column; align-items: center; border: 1px solid #ccc; background: #fff; margin: 1px; padding: 2px; min-width: 45px; }
.h-row-cell .num { font-size: 9px; font-weight: bold; }
.h-row-cell .name { font-size: 8px; transform: scale(0.85); white-space: nowrap; }

/* 台ボタン（共通） */
.m {
  width: 32px; height: 20px; border: 1px solid #777; background: #fff;
  font-size: 9px; font-weight: bold; text-align: center; line-height: 18px;
  cursor: pointer; user-select: none; margin: 1px; border-radius: 2px;
}
.m:hover { filter: brightness(0.9); }
.m.red    { background: #f44 !important; color: #fff; }
.m.yellow { background: #ff0 !important; color: #333; }
.m.blue   { background: #44f !important; color: #fff; }
</style>
